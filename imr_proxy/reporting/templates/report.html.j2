<!doctype html><html><head><meta charset="utf-8"><title>imr-proxy report</title><style>body{font-family:system-ui;margin:2rem}table{border-collapse:collapse;width:100%}td,th{border:1px solid #ddd;padding:.5rem}.high,.critical{color:#b91c1c}.medium{color:#a16207}.low{color:#1d4ed8}.info{color:#555}</style></head><body><h1>imr-proxy report</h1><p>Version: {{ version }}</p><table><tr><th>Method</th><th>URL</th><th>Status</th><th>Severity</th><th>Findings</th></tr>{% for f in flows %}<tr><td>{{ f.request.method }}</td><td>{{ f.request.url }}</td><td>{{ f.response.status_code if f.response else '' }}</td><td class="{{ f.highest_severity() }}">{{ f.highest_severity() }}</td><td>{{ f.findings|length }}</td></tr>{% endfor %}</table><h2>Findings</h2>{% for f in flows %}{% for x in f.findings %}<h3 class="{{ x.severity }}">{{ x.severity|upper }} - {{ x.title }}</h3><p><code>{{ x.id }}</code></p><p><b>Evidence:</b> {{ x.evidence }}</p><p><b>Impact:</b> {{ x.impact }}</p><p><b>Remediation:</b> {{ x.remediation }}</p>{% endfor %}{% endfor %}</body></html>
